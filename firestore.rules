rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions to check authentication and ownership
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Users Collection
    // Document ID matches the user's Auth UID
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Goals Collection
    match /goals/{goalId} {
      // Only the owner can read, update, or delete existing goals
      allow read, update, delete: if isOwner(resource.data.ownerUid);
      // Only allow creation if the user is setting themselves as the owner
      allow create: if isOwner(request.resource.data.ownerUid);
    }

    // Deposits Collection
    match /deposits/{depositId} {
      allow read, update, delete: if isOwner(resource.data.ownerUid);
      allow create: if isOwner(request.resource.data.ownerUid);
    }

    // Transactions Collection
    match /transactions/{transactionId} {
      allow read, update, delete: if isOwner(resource.data.ownerUid);
      allow create: if isOwner(request.resource.data.ownerUid);
    }
  }
}
